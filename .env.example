# ============================================================
# Lead Engine — Environment Variables Reference
# Copy to .env and fill in your values for local development.
# Never commit .env to git.
# ============================================================

# ── Database ────────────────────────────────────────────────
# Neon: Settings → Connection string → select "pooled"
# Local: postgresql://postgres:postgres@localhost:5432/leadengine
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/leadengine?sslmode=require

# ── AI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
AI_MODEL=gpt-4o-mini
LEAD_SCORE_THRESHOLD=7
AI_CONCURRENCY=5

# ── Security ────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(40))"
API_SECRET_KEY=change-me-generate-a-real-secret

# Comma-separated. Railway auto-generates frontend URL.
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.up.railway.app
ALLOWED_HOSTS=your-api.up.railway.app,localhost

# development | production
ENV=development
LOG_LEVEL=INFO
LOG_JSON=false

# ── Inbox 1 ─────────────────────────────────────────────────
INBOX_COUNT=1

INBOX_1_EMAIL=outreach@yourdomain.com
INBOX_1_SMTP_HOST=smtp.gmail.com
INBOX_1_SMTP_PORT=587
INBOX_1_SMTP_USER=outreach@yourdomain.com
INBOX_1_SMTP_PASSWORD=your-app-password-here
INBOX_1_IMAP_HOST=imap.gmail.com
INBOX_1_IMAP_PORT=993
INBOX_1_WARMUP_WEEK=1

# ── Inbox 2 (optional) ──────────────────────────────────────
# INBOX_2_EMAIL=outreach2@yourdomain.com
# INBOX_2_SMTP_HOST=smtp.gmail.com
# INBOX_2_SMTP_PORT=587
# INBOX_2_SMTP_USER=outreach2@yourdomain.com
# INBOX_2_SMTP_PASSWORD=your-app-password-here
# INBOX_2_IMAP_HOST=imap.gmail.com
# INBOX_2_IMAP_PORT=993
# INBOX_2_WARMUP_WEEK=1

# ── Inbox 3 (optional) ──────────────────────────────────────
# INBOX_3_EMAIL=outreach3@yourdomain.com
# ...

# ── Sender identity ─────────────────────────────────────────
SENDER_NAME=Your Name

# ── Email sending tuning ────────────────────────────────────
EMAIL_INTERVAL_MINUTES=30
EMAIL_BATCH_SIZE=10
SEND_MIN_DELAY=120
SEND_MAX_DELAY=240

# ── Scraping ────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6
PAIN_INTERVAL_HOURS=8
EMAIL_DISCOVERY_CONCURRENCY=5

# ── Monitoring ──────────────────────────────────────────────
REPLY_MONITOR_INTERVAL_MINUTES=30
DELIVERABILITY_INTERVAL_MINUTES=60
ANALYTICS_INTERVAL_HOURS=1
ANALYTICS_NIGHTLY_HOUR=2

# ── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Worker one-shot mode (for testing) ──────────────────────
# RUN_ONCE=true

# ── Debug ───────────────────────────────────────────────────
# SQL_ECHO=true
